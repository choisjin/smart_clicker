<script type="text/javascript">

	$(function(){
		var $event_box = $('.event .slide_box');
		var $paging = $('.event .pagingInfo');
		
		$event_box.on('init reInit afterChange', function (event, slick, currentSlide, nextSlide) {
			//currentSlide is undefined on init -- set it to 0 in this case (currentSlide is 0 based)
			var i = (currentSlide ? currentSlide : 0) + 1;
			$paging.html('<span class="current">' + i + '</span>' + '/' + '<span>' + slick.slideCount + '</span>' );
		}); 
		
		 $event_box.slick({
				infinite : true,
				slidesToShow : 1,
				slidesToScroll : 1,
				autoplay : true,
				autoplaySpeed : 5000,
				speed : 1000,
				dots : false, 
				arrow : false
			});
	});

</script>


<script type="text/javascript">
    function capslock(e) {
            var keyCode = 0;
            var shiftKey = false;
            keyCode = e.keyCode;
            shiftKey = e.shiftKey;
            if (((keyCode >= 65 && keyCode <= 90) && !shiftKey)
                    || ((keyCode >= 97 && keyCode <= 122) && shiftKey)) {
                show_capslock();
                //setTimeout("hide_capslock()", 3500);
            } else {
                hide_capslock();
            }
        }
 
    function show_capslock() {
         $("#caps_lock").show();
    }
 
    function hide_capslock() {
         $("#caps_lock").hide();
    }
</script>
	

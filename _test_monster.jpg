							$(document).ready(function() { 
								$("#btn_LoginM").on("click",function(){
								
									if ($.ValidChkM()==false) return;
									$("#frmLoginM").attr("action", "https://www.gersang.co.kr/member/loginProc.gs");
									$("#frmLoginM").attr("method", "post");
									$("#frmLoginM").submit();
						
								});
								$.ValidChkM = function(){
									obj = $("#GSuserIDM");
									if(obj.val().trim()==""){  
										alert("아이디를 입력하여 주시기 바랍니다.");
										obj.focus();
										return false;	
									}
									obj = $("#GSuserPWM");
									if(obj.val().trim()==""){  
										alert("비밀번호를 입력하여 주시기 바랍니다.");
										obj.focus();
										return false;	
									}
									return true;	
								}
								$("#GSuserIDM, #GSuserPWM").keydown(function(key) {
									if (key.keyCode == 13) {
										$("#btn_LoginM").trigger("click");
									}
								});

							});
						</script>

								

